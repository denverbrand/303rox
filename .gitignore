# Video assets — exclude everything by default, then allowlist the
# compressed/web-ready clips we want to deploy. This prevents 100MB+ raw
# originals or broken intermediate transcodes from sneaking in.
#
# Pattern: block everything, then re-allow each subdir, then block
# everything inside it, then allowlist each web-ready .mp4.
videos/*
!videos/stations/
videos/stations/*
!videos/stations/farmers-carry.mp4
!videos/stations/sled-push.mp4
!videos/stations/wall-balls.mp4
!videos/stations/burpee-bj.mp4
!videos/stations/skierg.mp4
!videos/hero/
videos/hero/*
# Allow all web-ready hero clips so you can swap which one plays without
# editing .gitignore each time. Keep clips compressed (<10MB ideally).
!videos/hero/*.mp4
